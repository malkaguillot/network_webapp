# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git — it is listed in .gitignore.
#
# For Streamlit Cloud deployment, enter these values in:
#   App settings → Secrets

# --- Dropbox credentials ---
# Run get_refresh_token.py once to obtain a long-lived access token (sl.u.xxx).
# Copy the printed value here.

DROPBOX_ACCESS_TOKEN  = "sl.u.your_long_lived_token_here"

# --- Data location ---
# Dropbox path to the folder that contains:
#   outlet_id_record.xlsx
#   Orbis/clean/actionnaires_rang0_with_rang1_TS.csv
#   Orbis/clean/actionnaires_rang1_with_rang2_TS.csv
#   Orbis/clean/actionnaires_rang2_with_rang3_TS.csv

# DROPBOX_DATA_FOLDER = "/path/to/your/data/source"
DROPBOX_DATA_FOLDER   = "/01_Research/projects-active/journalism-quality/data/source"
